@model IEnumerable<Garage_Management.DTO.CustomerDTO>

@{
    ViewData["Title"] = "Index";
}
@using Microsoft.AspNetCore.Http
@{
    int userid = Convert.ToInt32(Context.Request.Query["userid"]);
    int? id = Convert.ToInt32(Context.Request.Query["id"]);
}


<h1>Index</h1>
@if(userid == 0)
{
    <p>
        <a asp-action="Create" asp-route-userid="@userid">Create New</a>
</p>
}

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.FirstName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LastName)
            </th>
                    <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.FirstName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.LastName)
                </td>
            
                <td>
                    @if(item.CanEdit)
                    {
                        <a asp-action="Edit" asp-route-userid="@userid" asp-route-id="@item.CustomerId">Edit</a> 
                    }
                    <p></p>
                    @if(item.CanView)
                    {
                        <a asp-action="Details" asp-route-userid="@userid" asp-route-id="@item.CustomerId">Details</a> 
                    }
                    <p></p>
                    @if(userid == 0)
                    {
                        <a asp-action="Delete" asp-route-userid="@userid" asp-route-id="@item.CustomerId">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
