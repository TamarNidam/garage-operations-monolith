@model IEnumerable<Garage_Management.DTO.GaragePermissionDTO>

@{
    ViewData["Title"] = "Index";
}
@using Microsoft.AspNetCore.Http
@{
    int userid = Convert.ToInt32(Context.Request.Query["userid"]);
    int id = Convert.ToInt32(Context.Request.Query["id"]);
}

<h1>@Model.First().UserName</h1>
<h2>Garages Permissions</h2>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.GarageName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CanView)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CanEdit)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.GarageName)
                </td>
            <td>
                @Html.DisplayFor(modelItem => item.CanView)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CanEdit)
            </td>
            
            
            <td>
                    @if (userid == 0 && id != 0)
                    {
                        <a asp-action="Edit" asp-route-userid="@userid" asp-route-id="@item.PermissionId">Edit</a>
                    }
                    </td>
        </tr>
}
    </tbody>
</table>
