@model Garage_Management.DTO.GarageVisitDTO

@{
    ViewData["Title"] = "Create";
}
@using Microsoft.AspNetCore.Http
@{
    int? userid = Convert.ToInt32(Context.Request.Query["userid"]);
    int? id = Convert.ToInt32(Context.Request.Query["id"]);
}

<h1>Create</h1>

<h4>GarageVisit</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" asp-route-userid="@userid" asp-route-id="@id">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="VisitId" class="control-label"></label>
                <input asp-for="VisitId" class="form-control" />
                <span asp-validation-for="VisitId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CustomerId" class="control-label"></label>
                <select asp-for="CustomerId" class ="form-control" asp-items="ViewBag.CustomerId"></select>
            </div>
            <div class="form-group">
                <label asp-for="GarageId" class="control-label"></label>
                @if (ViewData["GarageId"] is SelectList garageList)
                {
                <select asp-for="GarageId" class ="form-control" asp-items="ViewBag.GarageId"></select>
                }
                else
                {
                    <input asp-for="GarageId" type="text" class="form-control" readonly value='@ViewData["GarageId"]' />
                    <span asp-validation-for="GarageId" class="text-danger"></span>
                }
            </div>
            <div class="form-group">
                <label asp-for="VisitDate" class="control-label"></label>
                <input asp-for="VisitDate" class="form-control" />
                <span asp-validation-for="VisitDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ServiceDescription" class="control-label"></label>
                <input asp-for="ServiceDescription" class="form-control" />
                <span asp-validation-for="ServiceDescription" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TotalCost" class="control-label"></label>
                <input asp-for="TotalCost" class="form-control" />
                <span asp-validation-for="TotalCost" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    @* <a asp-action="Index">Back to List</a> *@
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
