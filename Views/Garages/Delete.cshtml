@model Garage_Management.DTO.Garage_Visits_DTO

@{
    ViewData["Title"] = "Delete";
}
@using Microsoft.AspNetCore.Http
@{
    int userid = Convert.ToInt32(Context.Request.Query["userid"]);
    int? id = Convert.ToInt32(Context.Request.Query["id"]);
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Garage</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Garage.GarageName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Garage.GarageName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Garage.Address)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Garage.Address)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Garage.PhoneNumber)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Garage.PhoneNumber)
        </dd>
    </dl>
    
    <h2>Visits</h2>
    @if (Model.Visits.Count > 0)
    {
        <table class="table">
            <thead>
                <tr>
                    <th>
                        CustomerName
                    </th>
                    <th>
                        VisitDate
                    </th>
                    <th>
                        ServiceDescription
                    </th>
                    <th>
                        TotalCost
                    </th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Visits)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.CustomerName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.VisitDate)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.ServiceDescription)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.TotalCost)
                        </td>
                        
                    </tr>
                }
            </tbody>
        </table>
    }
    
    <form asp-action="Delete" asp-route-userid="@userid" asp-route-id="@Model.Garage.GarageId">
        <input type="hidden" asp-for="Garage.GarageId" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index" asp-route-userid="@userid">Back to List</a>
    </form>
</div>
