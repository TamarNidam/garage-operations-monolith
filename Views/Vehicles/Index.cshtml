@model IEnumerable<Garage_Management.DTO.VehicleDTO>

@{
    ViewData["Title"] = "Index";
}
@using Microsoft.AspNetCore.Http
@{
    int userid = Convert.ToInt32(Context.Request.Query["userid"]);
    int? id = Convert.ToInt32(Context.Request.Query["id"]);
}
<h1>Vehicles</h1>
@if (ViewBag.ifCanEdit)
{
   <p>
        <a asp-action="Create" asp-route-userid="@userid" asp-route-id="@id">Create New</a>
    </p>
}
   @if (userid == 0 && id == null)
{
    <p>
        <a asp-action="Create" asp-route-userid="@userid">Create New</a>
    </p>
}



<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Make)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Model)
            </th>
            @* <th>
                @Html.DisplayNameFor(model => model.Year)
            </th> *@
            <th>
                @Html.DisplayNameFor(model => model.Vin)
            </th>
          @*   <th>
                @Html.DisplayNameFor(model => model.Mileage)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LastServiceDate)
            </th> *@
            <th>
                @Html.DisplayNameFor(model => model.OwnerName)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Make)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Model)
            </td>
           @*  <td>
                @Html.DisplayFor(modelItem => item.Year)
            </td> *@
            <td>
                @Html.DisplayFor(modelItem => item.Vin)
            </td>
           @*  <td>
                @Html.DisplayFor(modelItem => item.Mileage)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LastServiceDate)
            </td> *@
            <td>
                    @Html.DisplayFor(modelItem => item.OwnerName)
            </td>
            <td>
                    @if (ViewBag.ifCanEdit || userid == 0)
                    {
                <a asp-action="Edit" asp-route-userid="@userid" asp-route-id="@item.VehicleId">Edit</a> 
                <p></p>
                        <a asp-action="Delete" asp-route-userid="@userid" asp-route-id="@item.VehicleId">Delete</a>
                  <p></p>  }
                    
                    @if (ViewBag.ifCanView || userid == 0)
                    {
                        <a asp-action="Details" asp-route-userid="@userid" asp-route-id="@item.VehicleId">Details</a>
                    }
            </td>
        </tr>
}
    </tbody>
</table>
